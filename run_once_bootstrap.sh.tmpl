#!/usr/bin/env bash
set -euo pipefail

OS="{{ .chezmoi.os }}"
ARCHITECTURE="$(uname -m)"
FEATURES="{{ join " " .features }}"
CONTEXT="{{ .context }}"
DEFAULT_SHELL="{{ .default_shell }}"
CLOUD_PROVIDERS="{{ join " " .cloud_providers }}"
AI_AGENTS="{{ join " " .ai_agents }}"

export OS
export ARCHITECTURE
export FEATURES
export CONTEXT
export DEFAULT_SHELL
export CLOUD_PROVIDERS
export AI_AGENTS

BOOTSTRAP_DIR="$(cd "$(dirname "$0")/bootstrap" && pwd)"
export BOOTSTRAP_DIR

# shellcheck source=bootstrap/lib.sh
. "${BOOTSTRAP_DIR}/lib.sh"

log_info "Detected OS:       ${OS}"
log_info "Enabled features:  ${FEATURES}"
log_info "Context:           ${CONTEXT}"
log_info "Cloud providers:   ${CLOUD_PROVIDERS}"

# ── Sistema de garantías de dependencias ──────────────────────────────────────
# Registra features completadas y valida deps antes de ejecutar cada una.

COMPLETED_FEATURES=""

run_feature() {
  local feature="$1"
  local script="${BOOTSTRAP_DIR}/features/${feature}.sh"

  # Validar dependencias declaradas en lib.sh::_feature_deps
  local deps
  deps="$(_feature_deps "${feature}")"
  for dep in ${deps}; do
    if ! echo " ${COMPLETED_FEATURES} " | grep -qw "${dep}"; then
      log_error "Feature '${feature}' requires '${dep}' to run first. Fix the order of 'features' in .chezmoidata.yaml"
    fi
  done

  log_step "Feature: ${feature}"
  bash "${script}"
  COMPLETED_FEATURES="${COMPLETED_FEATURES} ${feature}"
}

# ── Setup de SO ───────────────────────────────────────────────────────────────

log_step "OS setup: ${OS}"
case "${OS}" in
  linux)
    bash "${BOOTSTRAP_DIR}/os/linux.sh"
    ;;
  darwin)
    bash "${BOOTSTRAP_DIR}/os/darwin.sh"
    ;;
  *)
    log_error "Unsupported OS: ${OS}"
    ;;
esac

# ── Ejecución de features ─────────────────────────────────────────────────────

for feature in ${FEATURES}; do
  case "${feature}" in
    ai|brew|bundle|cloud|containers|gui|security|shell|vm)
      run_feature "${feature}"
      ;;
    *)
      log_error "Unknown feature '${feature}'. Check 'features' list in .chezmoidata.yaml."
      ;;
  esac
done

log_info "Bootstrap completed. Restart the host for all changes to take effect."
